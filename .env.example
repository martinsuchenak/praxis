# Praxis Configuration
# Copy this file to .env and fill in the values.
# All values can also be set as environment variables.

# --- Required ---

BOT_API_KEY=             # LLM API key (never stored in bot source files)
BOT_BASE_URL=            # LLM API base URL (e.g. http://localhost:11434/v1)
BOT_MODEL=               # Default model name for new bots (e.g. qwen3.5-9b)

# --- Optional ---

BOT_TICK_INTERVAL=30         # Seconds between ticks (default: 30)
BOT_LOG_VERBOSE=false        # Set to true to disable log truncation for debugging
BOT_GOSSIP_SECRET=           # Shared secret for inter-bot message auth (empty = no auth)
BOT_STALE_THRESHOLD=120      # Seconds before a running bot is flagged STALE in control list
