# Praxis Configuration
# Copy this file to .env and fill in the values.
# All values can also be set as environment variables.

# --- Required ---

BOT_API_KEY=             # LLM API key (never stored in bot source files)
BOT_BASE_URL=            # LLM API base URL (e.g. http://localhost:11434/v1)
BOT_MODEL=               # Default model name for new bots (e.g. qwen3.5-9b)

# --- Optional ---

BOT_TICK_INTERVAL=30         # Seconds between ticks (default: 30)
BOT_LOG_VERBOSE=false        # Set to true to disable log truncation + write debug/tick-N.md dumps
BOT_GOSSIP_SECRET=           # Shared secret for inter-bot message auth (empty = no auth)
BOT_STALE_THRESHOLD=120      # Seconds before a running bot is flagged STALE in control list
BOT_MAX_BACKOFF=600          # Max backoff seconds after repeated tick errors (default: 600)
BOT_MAX_CONCURRENT=1         # Max concurrent LLM calls per model (default: 1, override per-model in models.json)
BOT_TICK_MAX_ITERATIONS=5    # Max tool-call iterations per tick (default: 5)
BOT_SCRIPT_TIMEOUT=30        # Shell command timeout via proxy (default: 30)
BOT_HTTP_ALLOWLIST=           # Comma-separated domains bots may call via http_request (default: unrestricted)
BOT_SHELL_ALLOWLIST=          # Comma-separated executables bots may run via shell proxy (default: unrestricted except curl/wget)
BOT_SHELL_SANDBOX=true        # Sandbox shell commands with bwrap on watchdog (default: true, requires bwrap)
BOT_SHELL_MOUNTS=             # Extra bwrap mounts: mode:host_path:container_path (comma-separated)
                               #   e.g. BOT_SHELL_MOUNTS=ro:/shared/data:/data,rw:/tmp/scratch:/scratch
BOT_WATCHDOG_PORT=37000       # Port for the watchdog gossip node (default: 37000)
